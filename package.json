{
  "name": "skin-zone-docs",
  "version": "1.0.0",
  "description": "Documentation for skin-zone",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npm run test:quality",
    "test:quality": "npm run lint:md && npm run check:images && npm run check:architecture",
    "test:links": "node tests/check-links.js",
    "test:links:internal": "node tests/check-links.js --internal-only",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "lint:md": "npx markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#docs\"",
    "check:links": "node tests/check-links.js",
    "check:images": "node tests/check-images.js",
    "check:architecture": "node tests/check-shopify-architecture.js && node tests/check-architecture-content.js",
    "docs:build": "node scripts/build-docs.js",
    "docs:serve": "npx serve docs -l 3000",
    "docs:preview": "npm run docs:build && npm run docs:serve",
    "ci:quality": "npm run lint:md && npm run check:images && npm run check:architecture",
    "ci:build": "npm run docs:build",
    "ci:e2e": "npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "axios": "^1.6.0",
    "docsify-cli": "^4.4.4",
    "glob": "^10.3.10",
    "markdownlint-cli2": "^0.12.0",
    "serve": "^14.2.1"
  }
}

